@model IEnumerable<WebAppSafeJourney.Models.Destination>

@{
    ViewData["Title"] = "Manage Destinations";
    // خلفية سادة لصفحات الإدارة عشان الجدول يكون مقروء ومريح لعين الأدمن
    ViewData["BgImage"] = "";
}

<div class="container mt-5 mb-5">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 rounded-3 shadow-sm" style="background-color: var(--lapis-blue); color: white; border-left: 5px solid var(--pharaoh-gold);">
        <h2 class="fw-bold mb-0" style="font-family: 'Cinzel', serif;">
            <i class="bi bi-map me-2 text-warning"></i> Sacred Destinations Vault
        </h2>
        <a asp-action="Create" class="btn btn-gold fw-bold px-4 shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Add New Site
        </a>
    </div>

    <!-- Table Section -->
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden" style="background-color: rgba(255, 255, 255, 0.95); border-top: 5px solid var(--pharaoh-gold) !important;">
        <div class="card-body p-0 table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background-color: var(--lapis-blue); color: white;">
                    <tr>
                        <th class="py-3 px-4">Image</th>
                        <th class="py-3">Name</th>
                        <th class="py-3">Region</th>
                        <th class="py-3">Status</th>
                        <th class="py-3 text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr style="border-bottom: 1px solid rgba(212, 175, 55, 0.2);">
                            <td class="px-4 py-3">
                                @if (!string.IsNullOrEmpty(item.CoverImageUrl))
                                {
                                    <img src="@item.CoverImageUrl" loading="lazy" alt="@item.Name" class="rounded shadow-sm" style="width: 80px; height: 60px; object-fit: cover; border: 2px solid var(--pharaoh-gold);" />
                                }
                                else
                                {
                                    <div class="rounded shadow-sm d-flex align-items-center justify-content-center" style="width: 80px; height: 60px; background-color: var(--lapis-blue); color: var(--pharaoh-gold);">
                                        <i class="bi bi-image fs-4"></i>
                                    </div>
                                }
                            </td>
                            <td class="fw-bold fs-5" style="color: var(--lapis-blue);">@item.Name</td>
                            <td>
                                <span class="badge px-3 py-2" style="background-color: var(--papyrus-bg); color: var(--lapis-blue); border: 1px solid var(--pharaoh-gold);">
                                    <i class="bi bi-geo-alt-fill me-1 text-warning"></i>@item.Region
                                </span>
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success px-3 py-2 shadow-sm"><i class="bi bi-check-circle me-1"></i> Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary px-3 py-2 shadow-sm"><i class="bi bi-x-circle me-1"></i> Inactive</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm px-3 fw-bold me-2" style="background-color: var(--papyrus-bg); color: var(--lapis-blue); border: 1px solid var(--lapis-blue);">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this sacred site? This action cannot be undone.');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger px-3 fw-bold">
                                        <i class="bi bi-trash3"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div class="text-center p-5">
                    <i class="bi bi-folder2-open display-1 text-muted mb-3 d-block"></i>
                    <h4 class="text-muted" style="font-family: 'Cinzel', serif;">The vault is currently empty.</h4>
                    <p class="text-muted">Start adding destinations to display them to the travelers.</p>
                </div>
            }
        </div>
    </div>
</div>