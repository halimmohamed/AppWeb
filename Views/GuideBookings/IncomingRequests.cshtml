@model IEnumerable<WebAppSafeJourney.Models.GuideBooking>
@using WebAppSafeJourney.Models.Enums

@{
    ViewData["Title"] = "Incoming Requests";
    ViewData["BgImage"] = ""; // خلفية سادة لتسهيل قراءة الطلبات
}

<div class="container mt-5 mb-5">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 rounded-3 shadow-sm" style="background-color: var(--lapis-blue); color: white; border-left: 5px solid var(--pharaoh-gold);">
        <h2 class="fw-bold mb-0" style="font-family: 'Cinzel', serif;">
            <i class="bi bi-inbox-fill text-warning me-2"></i> Incoming Guidance Requests
        </h2>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-sm border-0 fw-bold" style="border-left: 5px solid #198754;">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm border-0 fw-bold" style="border-left: 5px solid #dc3545;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
        </div>
    }

    <!-- Table -->
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden" style="background-color: rgba(255, 255, 255, 0.95); border-top: 5px solid var(--pharaoh-gold) !important;">
        <div class="card-body p-0 table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background-color: var(--lapis-blue); color: white;">
                    <tr>
                        <th class="py-3 px-4"><i class="bi bi-hash"></i></th>
                        <th class="py-3"><i class="bi bi-person"></i> Traveler</th>
                        <th class="py-3"><i class="bi bi-geo-alt"></i> Destination</th>
                        <th class="py-3"><i class="bi bi-calendar-event"></i> Tour Date</th>
                        <th class="py-3"><i class="bi bi-people"></i> Group Size</th>
                        <th class="py-3"><i class="bi bi-shield-check"></i> Status</th>
                        <th class="py-3 text-center"><i class="bi bi-gear"></i> Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr style="border-bottom: 1px solid rgba(212, 175, 55, 0.2);">
                            <td class="align-middle fw-bold px-4" style="color: var(--pharaoh-gold-dark);">#@item.Id</td>
                            <td class="align-middle fw-bold text-dark">@item.Tourist?.FullName</td>
                            <td class="align-middle fw-bold" style="color: var(--lapis-blue);">@item.Destination?.Name</td>
                            <td class="align-middle fw-semibold">
                                <span class="badge" style="background-color: var(--papyrus-bg); color: var(--lapis-blue); border: 1px solid var(--pharaoh-gold);">
                                    @item.TourDate.ToString("yyyy-MM-dd")
                                </span>
                            </td>
                            <td class="align-middle text-center fw-bold">
                                <span class="badge bg-secondary rounded-pill px-3">@item.NumberOfPeople</span>
                            </td>
                            <td class="align-middle">
                                @{
                                    var (badgeClass, label) = item.Status switch
                                    {
                                        GuideBookingStatus.Pending => ("bg-warning text-dark", "Pending"),
                                        GuideBookingStatus.Confirmed => ("bg-success", "Confirmed"),
                                        GuideBookingStatus.Rejected => ("bg-danger", "Rejected"),
                                        GuideBookingStatus.Completed => ("bg-info text-dark", "Completed"),
                                        _ => ("bg-secondary", "Cancelled")
                                    };
                                }
                                <span class="badge @badgeClass px-3 py-2 shadow-sm">@label</span>
                            </td>
                            <td class="align-middle text-center">
                                @if (item.Status == GuideBookingStatus.Pending)
                                {
                                    <button class="btn btn-sm btn-gold fw-bold shadow-sm me-1" data-bs-toggle="modal" data-bs-target="#confirmModal@(item.Id)"><i class="bi bi-check2"></i> Accept</button>
                                    <button class="btn btn-sm btn-danger fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#rejectModal@(item.Id)"><i class="bi bi-x-lg"></i> Reject</button>

                                    <!-- Confirm Modal -->
                                    <div class="modal fade" id="confirmModal@(item.Id)" tabindex="-1">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
                                                <form asp-action="Confirm" asp-route-id="@item.Id" method="post">
                                                    <div class="modal-header" style="background-color: var(--lapis-blue); color: var(--pharaoh-gold); border-bottom: 3px solid var(--pharaoh-gold);">
                                                        <h5 class="modal-title fw-bold" style="font-family: 'Cinzel', serif;">Seal the Agreement #@item.Id</h5>
                                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <div class="modal-body text-start p-4" style="background-color: var(--papyrus-bg);">
                                                        <label class="form-label fw-bold" style="color: var(--lapis-blue);">Message to Traveler (Optional)</label>
                                                        <textarea name="message" class="form-control border-warning shadow-sm" rows="3" placeholder="Welcome them or set a meeting point..."></textarea>
                                                    </div>
                                                    <div class="modal-footer border-0" style="background-color: var(--papyrus-bg);">
                                                        <button type="button" class="btn btn-outline-secondary fw-bold" data-bs-dismiss="modal">Cancel</button>
                                                        <button type="submit" class="btn btn-gold fw-bold px-4">Confirm Acceptance</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Reject Modal -->
                                    <div class="modal fade" id="rejectModal@(item.Id)" tabindex="-1">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
                                                <form asp-action="Reject" asp-route-id="@item.Id" method="post">
                                                    <div class="modal-header bg-danger text-white border-bottom-0">
                                                        <h5 class="modal-title fw-bold" style="font-family: 'Cinzel', serif;">Decline Request #@item.Id</h5>
                                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <div class="modal-body text-start p-4" style="background-color: var(--papyrus-bg);">
                                                        <label class="form-label fw-bold text-danger">Rejection Reason (Optional)</label>
                                                        <textarea name="reason" class="form-control border-danger shadow-sm" rows="3" placeholder="Explain why you cannot accept this request..."></textarea>
                                                    </div>
                                                    <div class="modal-footer border-0" style="background-color: var(--papyrus-bg);">
                                                        <button type="button" class="btn btn-outline-secondary fw-bold" data-bs-dismiss="modal">Back</button>
                                                        <button type="submit" class="btn btn-danger fw-bold px-4">Confirm Rejection</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else if (item.Status == GuideBookingStatus.Confirmed)
                                {
                                    <form asp-action="MarkCompleted" asp-route-id="@item.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-info text-dark fw-bold shadow-sm"><i class="bi bi-check-all"></i> Mark Completed</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small fw-bold fst-italic border rounded px-2 py-1 bg-light">Processed</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!Model.Any())
            {
                <div class="text-center p-5 text-muted">
                    <i class="bi bi-envelope-paper display-1 mb-3 d-block" style="color: var(--pharaoh-gold);"></i>
                    <h5 style="font-family: 'Cinzel', serif;">No incoming scrolls yet.</h5>
                </div>
            }
        </div>
    </div>
</div>