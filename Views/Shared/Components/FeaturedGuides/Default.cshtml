@model IEnumerable<WebAppSafeJourney.Models.Guide>

@if (Model != null && Model.Any())
{
    <div class="guides-scroll mb-5">
        @foreach (var guide in Model)
        {
            <div class="guide-mini-card shadow-sm">
                <div class="guide-avatar">
                    @(string.IsNullOrEmpty(guide.User?.FullName) ? "?" : guide.User.FullName!.Substring(0, 1).ToUpper())
                </div>
                <h6 class="fw-bold mb-1">@guide.User?.FullName</h6>
                <small class="text-muted d-block mb-3">
                    <i class="bi bi-geo-alt"></i>
                    @(guide.CoveredRegions != null && guide.CoveredRegions.Any()
                                ? guide.CoveredRegions.First().Region.ToString()
                                : "Egypt")
        </small>
        <a asp-controller="GuideBookings" asp-action="Create" asp-route-guideId="@guide.Id"
           class="btn btn-sm btn-outline-dark w-100" style="border-color: var(--pharaoh-gold); color: var(--lapis-blue);">
            Book Now
        </a>
    </div>
        }
    </div>
}
else
{
    <p class="text-muted text-center py-4">No guides available right now — check back soon.</p>
}