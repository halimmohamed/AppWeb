@model WebAppSafeJourney.ViewModels.LoginVM

@{
    ViewData["Title"] = "Sign In";
    
    ViewData["BgImage"] = "https://i.pinimg.com/1200x/f2/00/ae/f200ae0cf707e0d4504f255c32ab6f07.jpg";
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-5">
        <div class="card shadow-lg border-0 rounded-4" style="background-color: rgba(255, 255, 255, 0.95); border-top: 5px solid var(--pharaoh-gold) !important;">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="bi bi-person-badge fs-1" style="color: var(--lapis-blue);"></i>
                    <h2 class="fw-bold mt-2" style="color: var(--lapis-blue);">Welcome Back</h2>
                    <p class="text-muted">Enter your credentials to continue your journey.</p>
                </div>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                        <label asp-for="Email"><i class="bi bi-envelope"></i> Email address</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                        <label asp-for="Password"><i class="bi bi-lock"></i> Password</label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-gold py-3 fs-5">Sign In</button>
                    </div>
                </form>

                <div class="text-center mt-4">
                    <p class="mb-0">New to SafeJourney? <a asp-action="Register" style="color: var(--lapis-blue); font-weight: bold;">Sign up here</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}